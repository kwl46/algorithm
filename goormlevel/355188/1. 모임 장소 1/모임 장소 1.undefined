# -*- coding: utf-8 -*-
# UTF-8 encoding when using korean
import sys
input = sys.stdin.readline

N = int(input())

lst = []
x_lst = []
y_lst = []

for i in range(N):
	x, y = map(int,input().split())
	x_lst.append(x)
	y_lst.append(y)
	lst.append((x,y))

x_lst.sort()
y_lst.sort()

mid_x = x_lst[len(x_lst)//2]
mid_y = y_lst[len(y_lst)//2]
ans = 0

for i in range(N):
	ans += abs(mid_x - lst[i][0]) + abs(mid_y - lst[i][1])

print(ans)






